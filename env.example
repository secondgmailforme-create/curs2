# ============================================================
# ПОРТЫ НА ХОСТЕ (можно менять)
# ============================================================
BACKEND_PORT_HOST=3001
DB_PORT_HOST=5432
REDIS_PORT_HOST=6379
MAILPIT_SMTP_PORT_HOST=1025
MAILPIT_UI_PORT_HOST=8025

# ============================================================
# БАЗА ДАННЫХ PostgreSQL
# ============================================================
DB_NAME=helpdesk
DB_USER=helpdesk
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================
# ПРИЛОЖЕНИЕ
# ============================================================
NODE_ENV=production
PORT=3001
FRONTEND_URL=http://localhost:3001

# ============================================================
# СЕКРЕТЫ - СГЕНЕРИРУЙ НОВЫЕ!
# ============================================================
JWT_SECRET=GENERATE_WITH_openssl_rand_-hex_32
JWT_EXPIRES_IN=7d
SESSION_SECRET=GENERATE_WITH_openssl_rand_-hex_32

# ============================================================
# SMTP (Gmail)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=your_email@gmail.com
EMAIL_USER=your_email@gmail.com

# ============================================================
# AI / Классификатор
# ============================================================
AI_API_URL=http://host.docker.internal:1234/v1
AI_MODEL_NAME=google/gemma-3-12b
CLASSIFIER_URL=http://host.docker.internal:8009

# ============================================================
# OAuth (опционально)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_CALLBACK_URL=